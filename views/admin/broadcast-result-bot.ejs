<%- include('partials/header') %>

<div class="flex-grow flex items-center justify-center py-6 relative overflow-hidden theme-transition">
  
  <div class="absolute top-[50%] left-[50%] translate-x-[-50%] translate-y-[-50%] w-[450px] h-[450px] rounded-full bg-indigo-900/10 blur-[120px] pointer-events-none"></div>

  <div class="w-full max-w-md z-10 relative">
    <div class="rounded-[2.5rem] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 backdrop-blur-xl p-8 shadow-sm dark:glow-effect theme-transition">
      
      <div class="mb-6 flex items-center justify-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 dark:text-emerald-400 text-2xl shadow-inner">
          <i class="fa-solid fa-circle-check animate-bounce"></i>
        </div>
      </div>
      <h1 class="text-center text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Broadcast <span class="text-blue-600 dark:text-gradient">Selesai!</span></h1>
      <p class="text-center text-xs text-slate-500 dark:text-slate-400 mt-1">Laporan eksekusi pengiriman pesan massal ke gateway Telegram.</p>

      <div class="grid gap-4 grid-cols-2 mt-8 mb-6">
        <div class="rounded-2xl bg-slate-50 dark:bg-slate-950/60 border border-emerald-500/30 dark:border-emerald-500/20 p-5 text-center theme-transition shadow-inner">
          <p class="text-[10px] font-bold text-emerald-600 dark:text-emerald-500 uppercase tracking-wider mb-1">Berhasil</p>
          <p class="text-3xl font-black text-emerald-500 dark:text-emerald-400 font-mono"><%= success %></p>
        </div>
        <div class="rounded-2xl bg-slate-50 dark:bg-slate-950/60 border border-red-500/30 dark:border-red-500/20 p-5 text-center theme-transition shadow-inner">
          <p class="text-[10px] font-bold text-red-600 dark:text-red-500 uppercase tracking-wider mb-1">Gagal</p>
          <p class="text-3xl font-black text-red-500 dark:text-red-400 font-mono"><%= failed %></p>
        </div>
      </div>

      <div class="mb-6 bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800/80 rounded-2xl p-4 theme-transition">
        <div class="mb-2 flex items-center justify-between text-xs font-semibold">
          <span class="text-slate-500 dark:text-slate-400">Success Rate System</span>
          <span class="text-cyan-600 dark:text-cyan-400 font-mono font-bold"><%= successRate %>%</span>
        </div>
        <div class="h-2 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-950 border border-slate-300 dark:border-slate-800">
          <div class="h-full bg-gradient-to-r from-cyan-500 to-indigo-500 transition-all duration-500" style="width: <%= successRate %>%"></div>
        </div>
      </div>

      <div class="rounded-2xl bg-slate-100 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-5 mb-8 theme-transition">
        <p class="text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-2.5 flex items-center gap-1.5">
          <i class="fa-solid fa-server text-[11px]"></i> Detail Antrean Jaringan
        </p>
        <div class="space-y-1.5 text-xs font-semibold text-slate-600 dark:text-slate-400 font-mono">
          <div class="flex justify-between border-b border-slate-200 dark:border-slate-900 pb-1.5">
            <span>Total Target:</span>
            <span class="text-slate-900 dark:text-white font-bold"><%= users.length %> User</span>
          </div>
          <div class="flex justify-between pt-0.5">
            <span>Status Sinkron:</span>
            <span class="text-emerald-600 dark:text-emerald-400 font-bold">SAVED_IN_LOGS</span>
          </div>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 border-t border-slate-100 dark:border-slate-800/80 pt-6">
        <a href="/admin" class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 px-4 py-3.5 text-xs font-bold text-white shadow-xl shadow-indigo-600/5 transition-all duration-300 hover:from-blue-500 hover:to-indigo-500 hover:scale-[1.02] active:scale-[0.98] cursor-pointer">
          <i class="fa-solid fa-house text-[10px]"></i> Dashboard
        </a>
        <a href="/admin/logout" class="inline-flex items-center justify-center gap-2 rounded-xl bg-slate-100 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 px-4 py-3.5 text-xs font-bold text-slate-600 dark:text-slate-400 transition hover:bg-slate-200 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200">
          <i class="fa-solid fa-right-from-bracket text-[10px]"></i> Keluar Sesi
        </a>
      </div>

    </div>
  </div>

</div>

<%- include('partials/footer') %>