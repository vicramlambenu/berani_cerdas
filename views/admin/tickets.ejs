<%- include('partials/header') %>

<div class="mx-auto max-w-4xl z-10 relative theme-transition">
  
  <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800/60 backdrop-blur-md rounded-3xl p-6 shadow-sm theme-transition">
    <div>
      <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tight flex items-center gap-2">
        <i class="fa-solid fa-ticket text-amber-500 text-xl"></i> Eskalasi Tiket User
      </h1>
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
        Daftar pertanyaan di luar konteks (*Out-of-Scope*) yang memerlukan intervensi jawaban manual admin.
      </p>
    </div>
    <a href="/admin" class="inline-flex items-center justify-center gap-2 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-5 py-3 text-xs font-bold text-slate-700 dark:text-slate-300 transition hover:bg-slate-100 dark:hover:bg-slate-700/50 shadow-sm">
      <i class="fa-solid fa-arrow-left text-[10px]"></i> Dashboard
    </a>
  </div>

  <div class="space-y-5">
    
    <% if (tickets.length === 0) { %>
      <div class="rounded-[2rem] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 p-10 text-center text-slate-400 dark:text-slate-500 font-medium italic shadow-sm theme-transition">
        <div class="flex flex-col items-center justify-center gap-2">
          <span class="text-3xl">🎉</span>
          <span class="text-sm font-semibold text-slate-600 dark:text-slate-400">Seluruh antrean bersih. Tidak ada tiket pengaduan aktif saat ini.</span>
        </div>
      </div>
    <% } %>

    <% tickets.forEach(function(t) { %>
      <div class="rounded-[2rem] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800/80 p-6 shadow-sm border-l-4 <%= t.status === 'pending' ? 'border-l-amber-500' : 'border-l-emerald-500' %> theme-transition duration-150">
        
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full <%= t.status === 'pending' ? 'bg-amber-500 animate-pulse' : 'bg-emerald-500' %>"></span>
            <span class="font-bold text-slate-900 dark:text-white text-sm"><%= t.sender_name %></span>
            <span class="font-mono text-[10px] text-slate-400 dark:text-slate-500 tracking-wider">ID: <%= t.chat_id %></span>
          </div>
          
          <span class="px-2.5 py-1 rounded-md text-[9px] font-black tracking-wider border <%= t.status === 'pending' ? 'bg-amber-500/10 border-amber-500/20 text-amber-600 dark:text-amber-400' : 'bg-emerald-500/10 border-emerald-500/20 text-emerald-600 dark:text-emerald-400' %>">
            <%= t.status.toUpperCase() %>
          </span>
        </div>
        
        <div class="bg-slate-100 dark:bg-slate-950 border border-slate-200 dark:border-slate-800/80 rounded-xl p-4 mb-4 font-sans text-xs text-slate-700 dark:text-slate-300 leading-relaxed italic font-medium theme-transition">
          "<%= t.user_question %>"
        </div>

        <% if (t.status === 'pending') { %>
          <form action="/admin/tickets/reply" method="POST" class="mt-4 flex flex-col sm:flex-row gap-2.5">
            <input type="hidden" name="ticket_id" value="<%= t.id %>">
            <input type="hidden" name="chat_id" value="<%= t.chat_id %>">
            
            <div class="relative flex-1 flex items-center">
              <span class="absolute left-4 text-slate-400 dark:text-slate-600 text-xs"><i class="fa-solid fa-reply"></i></span>
              <input 
                type="text" 
                name="jawaban_admin" 
                placeholder="Tulis instruksi atau jawaban manual untuk dikirim ke Telegram user..." 
                required 
                class="w-full bg-slate-50 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800 rounded-xl pl-11 pr-4 py-3.5 text-xs text-slate-800 dark:text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 placeholder:text-slate-400 dark:placeholder:text-slate-600"
              >
            </div>
            
            <button type="submit" class="rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-3.5 text-xs font-bold text-white shadow-xl shadow-indigo-600/5 transition hover:from-blue-500 hover:to-indigo-500 hover:scale-[1.02] active:scale-[0.98] whitespace-nowrap cursor-pointer">
              <i class="fa-solid fa-paper-plane mr-1 text-[10px]"></i> Kirim Balasan Telegram
            </button>
          </form>
        <% } else { %>
          <p class="text-[11px] text-emerald-600 dark:text-emerald-400 font-bold flex items-center gap-1.5 pt-1">
            <i class="fa-solid fa-circle-check text-xs"></i> Tiket ini telah ditinjau dan sukses dijawab secara manual oleh tim admin.
          </p>
        <% } %>
      </div>
    <% }); %>
  </div>

</div>

<%- include('partials/footer') %>