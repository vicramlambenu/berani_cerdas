<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tiket Pengaduan — Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #0b0f19;
    }
    .glow-effect {
      box-shadow: 0 0 50px -10px rgba(99, 102, 241, 0.15);
    }
    .text-gradient {
      background: linear-gradient(135deg, #67e8f9 0%, #6366f1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
  </style>
</head>
<body class="min-h-screen text-slate-300 p-4 md:p-8 relative overflow-x-hidden selection:bg-indigo-500/30 selection:text-indigo-200">

  <div class="absolute top-[-10%] left-[-10%] w-[450px] h-[450px] rounded-full bg-indigo-900/10 blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[450px] h-[450px] rounded-full bg-cyan-900/10 blur-[120px] pointer-events-none"></div>

  <div class="mx-auto max-w-4xl z-10 relative">
    
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between bg-slate-900/40 border border-slate-800/60 backdrop-blur-md rounded-3xl p-6 glow-effect">
      <div>
        <h1 class="text-3xl font-extrabold text-white tracking-tight flex items-center gap-2">
          <i class="fa-solid fa-ticket text-amber-400 text-2xl"></i> Eskalasi <span class="text-gradient">Tiket User</span>
        </h1>
        <p class="mt-1 text-xs text-slate-400">Daftar pertanyaan di luar konteks (*Out-of-Scope*) yang memerlukan intervensi jawaban manual admin</p>
      </div>
      <a href="/admin" class="inline-flex items-center justify-center gap-2 rounded-xl bg-slate-800 border border-slate-700 px-5 py-3 text-xs font-bold text-slate-300 transition hover:bg-slate-700 hover:text-white">
        <i class="fa-solid fa-arrow-left text-[10px]"></i> Dashboard
      </a>
    </div>

    <div class="space-y-5">
      <% if (tickets.length === 0) { %>
        <div class="rounded-[2rem] bg-slate-900/40 border border-slate-800 p-10 text-center text-slate-500 font-medium italic shadow-xl">
          <div class="flex flex-col items-center justify-center gap-2">
            <span class="text-3xl">🎉</span>
            <span>Seluruh antrean bersih. Tidak ada tiket pengaduan aktif saat ini.</span>
          </div>
        </div>
      <% } %>

      <% tickets.forEach(function(t) { %>
        <div class="rounded-[2rem] bg-slate-900/40 border border-slate-800/80 p-6 glow-effect border-l-4 <%= t.status === 'pending' ? 'border-l-amber-500' : 'border-l-emerald-500' %> transition duration-150">
          
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full <%= t.status === 'pending' ? 'bg-amber-500 animate-pulse' : 'bg-emerald-500' %>"></span>
              <span class="font-bold text-white text-sm"><%= t.sender_name %></span>
              <span class="font-mono text-[10px] text-slate-500 tracking-wider">ID: <%= t.chat_id %></span>
            </div>
            
            <span class="px-2.5 py-1 rounded-md text-[9px] font-black tracking-wider border <%= t.status === 'pending' ? 'bg-amber-500/10 border-amber-500/20 text-amber-400' : 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400' %>">
              <%= t.status.toUpperCase() %>
            </span>
          </div>
          
          <div class="bg-slate-950 border border-slate-800/80 rounded-xl p-4 mb-4 font-sans text-xs text-slate-300 leading-relaxed italic">
            "<%= t.user_question %>"
          </div>

          <% if (t.status === 'pending') { %>
            <form action="/admin/tickets/reply" method="POST" class="mt-4 flex flex-col sm:flex-row gap-2.5">
              <input type="hidden" name="ticket_id" value="<%= t.id %>">
              <input type="hidden" name="chat_id" value="<%= t.chat_id %>">
              
              <div class="relative flex-1 flex items-center">
                <span class="absolute left-4 text-slate-600 text-xs"><i class="fa-solid fa-reply"></i></span>
                <input 
                  type="text" 
                  name="jawaban_admin" 
                  placeholder="Tulis instruksi atau jawaban manual untuk dikirim ke Telegram user..." 
                  required 
                  class="w-full bg-slate-950/60 border border-slate-800 rounded-xl pl-11 pr-4 py-3.5 text-xs text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 placeholder:text-slate-600"
                >
              </div>
              
              <button type="submit" class="rounded-xl bg-gradient-to-r from-cyan-500 to-indigo-600 px-6 py-3.5 text-xs font-bold text-white shadow-xl shadow-indigo-600/5 transition hover:from-cyan-400 hover:to-indigo-500 hover:scale-[1.02] active:scale-[0.98] whitespace-nowrap">
                <i class="fa-solid fa-paper-plane mr-1 text-[10px]"></i> Kirim Balasan Telegram
              </button>
            </form>
          <% } else { %>
            <p class="text-[11px] text-emerald-400 font-bold flex items-center gap-1.5 pt-1">
              <i class="fa-solid fa-circle-check text-xs"></i> Tiket ini telah ditinjau dan sukses dijawab secara manual oleh tim admin.
            </p>
          <% } %>
        </div>
      <% }); %>
    </div>

  </div>
</body>
</html>