<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login Operator — Berani Cerdas Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #0b0f19;
    }
    .glow-effect {
      box-shadow: 0 0 50px -10px rgba(99, 102, 241, 0.2);
    }
    .text-gradient {
      background: linear-gradient(135deg, #67e8f9 0%, #6366f1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center px-4 relative overflow-hidden selection:bg-indigo-500/30 selection:text-indigo-200">

  <div class="absolute top-[20%] left-[-10%] w-[450px] h-[450px] rounded-full bg-indigo-900/15 blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[450px] h-[450px] rounded-full bg-cyan-900/15 blur-[120px] pointer-events-none"></div>

  <div class="w-full max-w-md z-10">
    <div class="bg-slate-900/40 border border-slate-800 backdrop-blur-xl rounded-[2.5rem] p-8 md:p-10 glow-effect transition-all duration-300 hover:border-slate-700/50">
      
      <div class="text-center mb-8">
        <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-cyan-500/10 to-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-2xl shadow-inner">
          <i class="fa-solid fa-shield-cat"></i>
        </div>
        <h1 class="mt-5 text-3xl font-extrabold text-white tracking-tight">
          <span class="text-gradient">Berani Cerdas</span>
        </h1>
        <p class="mt-1.5 text-xs text-slate-500 font-medium tracking-wide uppercase">Gateway Security Protocol</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-5 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-xs font-semibold text-red-400 flex items-center gap-2.5">
          <i class="fa-solid fa-circle-exclamation animate-pulse text-sm"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/admin/do-login" method="POST" class="space-y-5">
        
        <div>
          <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Username Administrator</label>
          <div class="relative flex items-center">
            <span class="absolute left-4 text-slate-500 text-xs"><i class="fa-solid fa-user-shield"></i></span>
            <input
              type="text"
              name="username"
              placeholder="Masukkan akun username..."
              required
              autofocus
              class="w-full bg-slate-950/80 border border-slate-800 rounded-xl pl-11 pr-4 py-3.5 text-xs text-slate-200 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-sans placeholder:text-slate-600"
            />
          </div>
        </div>

        <div>
          <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Kunci Akses Password</label>
          <div class="relative flex items-center">
            <span class="absolute left-4 text-slate-500 text-xs"><i class="fa-solid fa-key"></i></span>
            <input
              type="password"
              name="password"
              placeholder="Masukkan pass-key rahasia..."
              required
              class="w-full bg-slate-950/80 border border-slate-800 rounded-xl pl-11 pr-4 py-3.5 text-xs text-slate-200 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-sans placeholder:text-slate-600"
            />
          </div>
        </div>

        <button type="submit" class="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-indigo-600 px-6 py-4 text-xs font-bold text-white shadow-lg shadow-indigo-600/10 transition-all duration-300 hover:from-cyan-400 hover:to-indigo-500 hover:scale-[1.02] active:scale-[0.98] mt-2">
          <i class="fa-solid fa-unlock-keyhole mr-1 text-[10px]"></i> Verifikasi & Masuk Panel Kendali
        </button>

      </form>

      <div class="mt-8 pt-4 border-t border-slate-800/60 text-center">
        <p class="text-[10px] font-mono text-slate-600 tracking-wide">
          CORE VER 2.0 • POWERED BY OPENCLAW INFRASTRUCTURE
        </p>
      </div>

    </div>
  </div>

</body>
</html>