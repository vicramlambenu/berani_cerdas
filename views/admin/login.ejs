<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login - Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-blue-600 to-blue-800 min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-3xl shadow-2xl p-8">
      <div class="text-center mb-8">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-blue-100 text-blue-600 text-4xl">
          🎓
        </div>
        <h1 class="mt-5 text-3xl font-extrabold text-gray-900">Berani Cerdas</h1>
        <p class="mt-2 text-gray-500">Panel Admin</p>
      </div>

      <% if (error) { %>
        <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <form action="/admin/do-login" method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Password Admin</label>
          <input
            type="password"
            name="password"
            placeholder="Masukkan password..."
            required
            autofocus
            class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200"
          />
        </div>

        <button type="submit" class="w-full rounded-2xl bg-blue-600 py-3 text-sm font-semibold text-white transition hover:bg-blue-700">
          🔓 Login
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-slate-500">Versi 2.0 - Admin Control Panel</p>
    </div>
  </div>
</body>
</html>
