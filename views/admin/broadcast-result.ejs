<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Broadcast Result - Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }</style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="rounded-3xl bg-white p-8 shadow-2xl">
      
      <div class="mb-6 flex items-center justify-center">
        <div class="flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-green-400 to-green-600 text-5xl text-white shadow-md">✅</div>
      </div>
      <h1 class="text-center text-3xl font-black text-slate-900 mb-2">Broadcast Selesai!</h1>
      <p class="text-center text-slate-500 mb-8">Hasil pengiriman pesan ke pengguna Telegram</p>

      <div class="grid gap-4 sm:grid-cols-2 mb-8">
        <div class="rounded-3xl bg-green-50 p-6 text-center border border-green-100">
          <p class="text-sm font-bold text-green-700 mb-2">Berhasil</p>
          <p class="text-4xl font-black text-green-600"><%= success %></p>
        </div>
        <div class="rounded-3xl bg-red-50 p-6 text-center border border-red-100">
          <p class="text-sm font-bold text-red-700 mb-2">Gagal</p>
          <p class="text-4xl font-black text-red-600"><%= failed %></p>
        </div>
      </div>

      <div class="mb-6">
        <div class="mb-3 flex items-center justify-between text-sm font-bold text-slate-700">
          <span>Success Rate System</span>
          <span class="text-blue-600"><%= successRate %>%</span>
        </div>
        <div class="h-3 overflow-hidden rounded-full bg-slate-200">
          <div class="h-full bg-gradient-to-r from-green-400 to-green-600" style="width: <%= successRate %>%"></div>
        </div>
      </div>

      <div class="rounded-3xl bg-blue-50/80 border border-blue-100 p-5 mb-8 text-slate-700">
        <p class="text-sm font-bold text-blue-600 mb-2">📊 Detail Antrean Telegram</p>
        <div class="space-y-1 text-xs font-semibold text-slate-600">
          <p>Total Target User: <span class="text-slate-900"><%= users.length %></span></p>
          <p>Status Log: <span class="text-emerald-600">Otomatis Masuk 'broadcast_logs'</span></p>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 border-t border-slate-100 pt-6">
        <a href="/admin" class="inline-flex items-center justify-center rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 px-4 py-3.5 text-sm font-bold text-white transition hover:from-blue-700 hover:to-purple-700 shadow-md hover:scale-[1.02] active:scale-[0.98]">
          🏠 Dashboard
        </a>
        <a href="/admin/logout" class="inline-flex items-center justify-center rounded-2xl bg-slate-100 border border-slate-200 px-4 py-3.5 text-sm font-bold text-slate-700 transition hover:bg-slate-200 shadow-sm">
          🚪 Logout
        </a>
      </div>

    </div>
  </div>
</body>
</html>