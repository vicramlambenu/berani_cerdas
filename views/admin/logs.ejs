<%- include('partials/header') %>

<div class="mx-auto max-w-5xl z-10 relative theme-transition">
  
  <div class="mb-8 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5 bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800/60 backdrop-blur-md rounded-3xl p-6 shadow-sm theme-transition">
    <div>
      <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tight flex items-center gap-2">
        <i class="fa-solid fa-clock-history text-indigo-500 dark:text-indigo-400 text-xl"></i> Log Audit Trail
      </h1>
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
        Riwayat pengawasan deteksi aktivitas operator admin secara real-time.
      </p>
    </div>
    
    <div class="flex flex-wrap items-center gap-3">
      <a href="/admin/download-csv" class="inline-flex items-center gap-2 rounded-xl bg-emerald-500/10 border border-emerald-500/20 px-4 py-3 text-xs font-bold text-emerald-600 dark:text-emerald-400 transition hover:bg-emerald-500 hover:text-white shadow-sm">
        <i class="fa-solid fa-file-csv text-[13px]"></i> Ekspor Excel (CSV)
      </a>

      <a href="/admin/download-log" class="inline-flex items-center gap-2 rounded-xl bg-amber-500/10 border border-amber-500/20 px-4 py-3 text-xs font-bold text-amber-600 dark:text-amber-500 transition hover:bg-amber-500 dark:hover:bg-amber-500 hover:text-slate-900 dark:hover:text-slate-950 shadow-sm">
        <i class="fa-solid fa-file-pdf text-[13px]"></i> Ekspor PDF Resmi
      </a>

      <a href="/admin" class="inline-flex items-center justify-center gap-2 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 text-xs font-bold text-slate-700 dark:text-slate-300 transition hover:bg-slate-100 dark:hover:bg-slate-700/50 shadow-sm">
        <i class="fa-solid fa-house text-[10px]"></i> Dashboard
      </a>
    </div>
  </div>

  <div class="rounded-[2rem] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 p-6 md:p-8 shadow-sm theme-transition">
    <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-800/80 shadow-sm">
      <table class="w-full border-collapse text-left text-xs">
        <thead>
          <tr class="bg-slate-100 dark:bg-slate-950 text-slate-600 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800 font-mono uppercase tracking-wider text-[10px]">
            <th class="px-6 py-4 font-bold">Stempel Waktu</th>
            <th class="px-6 py-4 font-bold">Operator Terautentikasi</th>
            <th class="px-6 py-4 font-bold">Tingkat Hak Akses</th>
            <th class="px-6 py-4 font-bold">Aktivitas & Mutasi Sistem</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 dark:divide-slate-800/60 bg-white dark:bg-slate-900/20">
          <% if (logs && logs.length > 0) { %>
            <% logs.forEach(function(log) { %>
              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition duration-150">
                <td class="px-6 py-4 font-mono text-cyan-600 dark:text-cyan-400 font-bold whitespace-nowrap tracking-wide">
                  <%= new Date(log.waktu).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %>
                </td>
                <td class="px-6 py-4 font-bold text-slate-900 dark:text-white"><%= log.operator %></td>
                
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (log.role === 'kepala admin') { %>
                    <span class="px-2.5 py-1 rounded-md bg-purple-500/10 border border-purple-500/20 text-purple-600 dark:text-purple-400 text-[10px] uppercase font-black tracking-wider">
                      👑 KEPALA ADMIN
                    </span>
                  <% } else { %>
                    <span class="px-2.5 py-1 rounded-md bg-blue-500/10 border border-blue-500/20 text-blue-600 dark:text-blue-400 text-[10px] uppercase font-black tracking-wider">
                      👤 STAFF ADMIN
                    </span>
                  <% } %>
                </td>
                
                <td class="px-6 py-4 text-slate-700 dark:text-slate-300 font-semibold leading-relaxed max-w-sm"><%= log.aksi %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500 font-medium italic">
                <div class="flex flex-col items-center justify-center gap-2">
                  <span class="text-3xl">📭</span>
                  <span class="text-sm font-semibold text-slate-600 dark:text-slate-400">Belum ada rekam jejak aktivitas log audit trail yang terdaftar di basis data.</span>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<%- include('partials/footer') %>