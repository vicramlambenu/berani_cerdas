<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>System Logs - Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }</style>
</head>
<body class="min-h-screen p-4 md:p-8 text-slate-900">
  <div class="mx-auto max-w-5xl">
    
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-4xl font-extrabold text-white drop-shadow-lg">📋 Log Audit Trail</h1>
        <p class="mt-2 text-blue-100">Riwayat deteksi aktivitas admin secara real-time</p>
      </div>
      
      <div class="flex flex-wrap items-center gap-3">
        
        <a href="/admin/download-csv" class="inline-flex items-center gap-2 rounded-2xl bg-emerald-600 hover:bg-emerald-500 px-5 py-3 text-sm font-bold text-white transition shadow-lg shadow-emerald-600/20 active:scale-[0.98]">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 0 1-1.125-1.125M3.375 19.5v-1.5M21 19.5a1.125 1.125 0 0 0 1.125-1.125M21 19.5v-1.5M3.375 18h17.25M3.375 15h17.25m-17.25-3h17.25m-17.25-3h17.25m-17.25-3h17.25" />
          </svg>
          Ekspor Excel (CSV)
        </a>

        <a href="/admin/download-log" class="inline-flex items-center gap-2 rounded-2xl bg-amber-500 hover:bg-amber-400 px-5 py-3 text-sm font-bold text-slate-950 transition shadow-lg shadow-amber-500/20 active:scale-[0.98]">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
          Ekspor PDF Resmi
        </a>

        <a href="/admin" class="rounded-2xl bg-white/20 backdrop-blur-md px-5 py-3 text-sm font-bold text-white transition hover:bg-white/30 shadow-md active:scale-[0.98]">
          Dashboard
        </a>
      </div>
    </div>

    <div class="rounded-3xl bg-white p-6 shadow-2xl overflow-hidden border border-white/10">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm border-collapse">
          <thead>
            <tr class="bg-slate-50 text-slate-500 border-b border-slate-100">
              <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Waktu</th>
              <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Operator</th>
              <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Role</th>
              <th class="px-6 py-4 font-bold uppercase tracking-wider text-xs">Aktivitas Sistem</th>
            </tr>
          </thead>
          <tbody>
            <% if (logs && logs.length > 0) { %>
              <% logs.forEach(function(log) { %>
                <tr class="border-b border-slate-100 hover:bg-slate-50/80 transition">
                  <td class="px-6 py-4 font-mono text-xs text-slate-500">
                    <%= new Date(log.waktu).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %>
                  </td>
                  <td class="px-6 py-4 font-bold text-slate-800"><%= log.operator %></td>
                  <td class="px-6 py-4">
                    <span class="rounded-full px-3 py-1 text-xs font-black tracking-wide <%= log.role === 'kepala admin' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' %>">
                      <%= log.role.toUpperCase() %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-slate-600 font-medium"><%= log.aksi %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="4" class="px-6 py-12 text-center text-slate-400 font-semibold">
                  📭 Belum ada riwayat log audit aktivitas yang tercatat di sistem.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</body>
</html>