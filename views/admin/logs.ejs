<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Log Audit Trail — Berani Cerdas Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #0b0f19;
    }
    .glow-effect {
      box-shadow: 0 0 50px -10px rgba(99, 102, 241, 0.15);
    }
    .text-gradient {
      background: linear-gradient(135deg, #67e8f9 0%, #6366f1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    /* Kustomisasi Scrollbar agar Elegan */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #0f172a; }
    ::-webkit-scrollbar-thumb { background: #334155; border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: #475569; }
  </style>
</head>
<body class="min-h-screen text-slate-300 p-4 md:p-8 relative overflow-x-hidden selection:bg-indigo-500/30 selection:text-indigo-200">

  <div class="absolute top-[-10%] left-[-10%] w-[450px] h-[450px] rounded-full bg-indigo-900/10 blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[450px] h-[450px] rounded-full bg-cyan-900/10 blur-[120px] pointer-events-none"></div>

  <div class="mx-auto max-w-5xl z-10 relative">
    
    <div class="mb-8 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5 bg-slate-900/40 border border-slate-800/60 backdrop-blur-md rounded-3xl p-6 glow-effect">
      <div>
        <h1 class="text-3xl font-extrabold text-white tracking-tight flex items-center gap-2">
          <i class="fa-solid fa-clock-history text-indigo-400 text-2xl"></i> Log <span class="text-gradient">Audit Trail</span>
        </h1>
        <p class="mt-1 text-xs text-slate-400">Riwayat pengawasan deteksi aktivitas operator admin secara real-time</p>
      </div>
      
      <div class="flex flex-wrap items-center gap-3">
        <a href="/admin/download-csv" class="inline-flex items-center gap-2 rounded-xl bg-emerald-500/10 border border-emerald-500/20 px-4 py-3 text-xs font-bold text-emerald-400 transition hover:bg-emerald-500 hover:text-white shadow-lg shadow-emerald-500/5">
          <i class="fa-solid fa-file-csv text-[13px]"></i> Ekspor Excel (CSV)
        </a>

        <a href="/admin/download-log" class="inline-flex items-center gap-2 rounded-xl bg-amber-500/10 border border-amber-500/20 px-4 py-3 text-xs font-bold text-amber-400 transition hover:bg-amber-500 hover:text-slate-950 shadow-lg shadow-amber-500/5">
          <i class="fa-solid fa-file-pdf text-[13px]"></i> Ekspor PDF Resmi
        </a>

        <a href="/admin" class="inline-flex items-center justify-center gap-2 rounded-xl bg-slate-800 border border-slate-700 px-4 py-3 text-xs font-bold text-slate-300 transition hover:bg-slate-700 hover:text-white">
          <i class="fa-solid fa-house text-[10px]"></i> Dashboard
        </a>
      </div>
    </div>

    <div class="rounded-[2rem] bg-slate-900/40 border border-slate-800 p-6 md:p-8 glow-effect">
      <div class="overflow-x-auto rounded-xl border border-slate-800/80">
        <table class="w-full border-collapse text-left text-xs">
          <thead>
            <tr class="bg-slate-950 text-slate-400 border-b border-slate-800 font-mono uppercase tracking-wider text-[10px]">
              <th class="px-6 py-4 font-bold">Stempel Waktu</th>
              <th class="px-6 py-4 font-bold">Operator Terautentikasi</th>
              <th class="px-6 py-4 font-bold">Tingkat Hak Akses</th>
              <th class="px-6 py-4 font-bold">Aktivitas & Mutasi Sistem</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 bg-slate-900/20">
            <% if (logs && logs.length > 0) { %>
              <% logs.forEach(function(log) { %>
                <tr class="hover:bg-slate-800/30 transition duration-150">
                  <td class="px-6 py-4 font-mono text-cyan-400 font-semibold whitespace-nowrap tracking-wide">
                    <%= new Date(log.waktu).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %>
                  </td>
                  <td class="px-6 py-4 font-bold text-white"><%= log.operator %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if (log.role === 'kepala admin') { %>
                      <span class="px-2.5 py-1 rounded-md bg-purple-500/10 border border-purple-500/20 text-purple-400 text-[10px] uppercase font-black tracking-wider">
                        👑 KEPALA ADMIN
                      </span>
                    <% } else { %>
                      <span class="px-2.5 py-1 rounded-md bg-blue-500/10 border border-blue-500/20 text-blue-400 text-[10px] uppercase font-black tracking-wider">
                        👤 STAFF ADMIN
                      </span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-slate-300 font-medium leading-relaxed max-w-sm"><%= log.aksi %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="4" class="px-6 py-12 text-center text-slate-500 font-medium italic">
                  <div class="flex flex-col items-center justify-center gap-2">
                    <span class="text-3xl">📭</span>
                    <span>Belum ada rekam jejak aktivitas log audit trail yang terdaftar di basis data.</span>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</body>
</html>