<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>System Logs - Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }</style>
</head>
<body class="min-h-screen p-4 md:p-8 text-slate-900">
  <div class="mx-auto max-w-5xl">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-4xl font-extrabold text-white drop-shadow-lg">📋 Log Audit Trail</h1>
        <p class="mt-2 text-blue-100">Riwayat deteksi aktivitas admin secara real-time</p>
      </div>
      <a href="/admin" class="rounded-2xl bg-white/20 backdrop-blur-md px-5 py-3 text-sm font-bold text-white transition hover:bg-white/30 shadow-md">🏠 Dashboard</a>
    </div>

    <div class="rounded-3xl bg-white p-6 shadow-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm border-collapse">
          <thead>
            <tr class="bg-slate-100 text-slate-700 border-b">
              <th class="px-6 py-4 font-bold">Waktu</th>
              <th class="px-6 py-4 font-bold">Operator</th>
              <th class="px-6 py-4 font-bold">Role</th>
              <th class="px-6 py-4 font-bold">Aktivitas Sistem</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(log) { %>
              <tr class="border-b hover:bg-slate-50 transition">
                <td class="px-6 py-4 font-mono text-xs text-slate-500"><%= new Date(log.waktu).toLocaleString('id-ID') %></td>
                <td class="px-6 py-4 font-bold text-slate-800"><%= log.operator %></td>
                <td class="px-6 py-4"><span class="rounded-full px-3 py-1 text-xs font-bold <%= log.role === 'kepala admin' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' %>"><%= log.role %></span></td>
                <td class="px-6 py-4 text-slate-700 font-medium"><%= log.aksi %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>