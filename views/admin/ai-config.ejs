<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pengaturan AI & Knowledge Base - Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }</style>
</head>
<body class="min-h-screen p-4 md:p-8 text-slate-900">
  <div class="mx-auto max-w-4xl">
    
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-4xl font-extrabold text-white drop-shadow-lg">⚙️ Pengaturan AI Gemini</h1>
        <p class="mt-2 text-blue-100">Modifikasi instruksi dasar dan basis pengetahuan Agen AI secara dinamis</p>
      </div>
      <a href="/admin" class="inline-flex items-center justify-center rounded-2xl bg-white/20 backdrop-blur-md px-5 py-3 text-sm font-bold text-white transition hover:bg-white/30 shadow-md">
        🏠 Dashboard
      </a>
    </div>

    <% if (typeof query !== 'undefined' && query.success) { %>
      <div class="mb-6 rounded-2xl bg-emerald-500 p-4 font-semibold text-white shadow-lg flex items-center gap-3">
        <span>✅</span> Data Knowledge Base AI Berhasil Diperbarui di Supabase! OpenClaw otomatis tersinkronisasi.
      </div>
    <% } %>

    <div class="rounded-3xl bg-white p-8 shadow-2xl">
      <form action="/admin/ai-config/save" method="POST" class="space-y-6">
        
        <div>
          <label class="block text-sm font-bold text-slate-800 mb-2">🤖 System Instruction (Kepribadian AI)</label>
          <p class="text-xs text-slate-500 mb-3">Aturan dasar perilaku AI. Contoh: "Kamu adalah bot ramah yang melayani informasi pendaftaran beasiswa."</p>
          <textarea name="system_instruction" rows="4" required placeholder="Tulis instruksi sistem untuk membatasi ruang lingkup chat AI di sini..." class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 font-medium outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200"><%= config?.system_instruction || '' %></textarea>
        </div>

        <div>
          <label class="block text-sm font-bold text-slate-800 mb-2">📚 Knowledge Base (Basis Pengetahuan Beasiswa)</label>
          <p class="text-xs text-slate-500 mb-3">Suapi informasi sedetail mungkin di sini agar AI tahu jawaban seputar syarat pendaftaran, kuota, atau batas waktu.</p>
          <textarea name="knowledge_base" rows="10" required placeholder="Tulis semua dokumen atau informasi penting seputar beasiswa di sini..." class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 font-medium outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200"><%= config?.knowledge_base || '' %></textarea>
        </div>

        <div class="border-t border-slate-100 pt-6 flex gap-4">
          <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-4 text-sm font-bold text-white transition hover:from-blue-700 hover:to-purple-700 shadow-lg hover:scale-[1.01] active:scale-[0.99]">
            💾 Simpan & Perbarui Memori AI
          </button>
          <a href="/admin" class="inline-flex items-center justify-center rounded-2xl bg-slate-100 border border-slate-200 px-6 py-4 text-sm font-bold text-slate-700 transition hover:bg-slate-200 shadow-sm">
            Batal
          </a>
        </div>

      </form>
    </div>

  </div>

  <script>
    if (window.location.search.includes('success=1')) {
      const msg = document.createElement('div');
      msg.className = "fixed bottom-5 right-5 rounded-2xl bg-emerald-600 text-white font-bold py-3 px-6 shadow-2xl transition duration-500";
      msg.innerText = "🎉 Sukses memperbarui memori AI!";
      document.body.appendChild(msg);
      setTimeout(() => msg.remove(), 4000);
    }
  </script>
</body>
</html>