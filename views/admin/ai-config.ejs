<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pengaturan AI & Team Management — Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #0b0f19;
    }
    .glow-effect {
      box-shadow: 0 0 50px -10px rgba(99, 102, 241, 0.15);
    }
    .text-gradient {
      background: linear-gradient(135deg, #67e8f9 0%, #6366f1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    /* Kustomisasi Scrollbar agar Elegan */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #0f172a; }
    ::-webkit-scrollbar-thumb { background: #334155; border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: #475569; }
  </style>
</head>
<body class="min-h-screen text-slate-300 p-4 md:p-8 relative overflow-x-hidden selection:bg-indigo-500/30 selection:text-indigo-200">

  <div class="absolute top-[-10%] left-[-10%] w-[450px] h-[450px] rounded-full bg-indigo-900/10 blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[450px] h-[450px] rounded-full bg-cyan-900/10 blur-[120px] pointer-events-none"></div>

  <div class="mx-auto max-w-4xl z-10 relative">
    
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between bg-slate-900/40 border border-slate-800/60 backdrop-blur-md rounded-3xl p-6 glow-effect">
      <div>
        <h1 class="text-3xl font-extrabold text-white tracking-tight flex items-center gap-2">
          <i class="fa-solid fa-microchip text-indigo-400 text-2xl"></i> Konfigurasi <span class="text-gradient">Core AI</span>
        </h1>
        <p class="mt-1 text-xs text-slate-400">Modifikasi instruksi dasar dan basis pengetahuan Agen AI secara dinamis</p>
      </div>
      <a href="/admin" class="inline-flex items-center justify-center gap-2 rounded-xl bg-slate-800 border border-slate-700 px-5 py-3 text-xs font-bold text-slate-300 transition hover:bg-slate-700 hover:text-white">
        <i class="fa-solid fa-house text-[11px]"></i> Dashboard
      </a>
    </div>

    <% if (typeof req !== 'undefined' && req.query.success) { %>
      <div class="mb-6 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-xs font-semibold text-emerald-400 flex items-center gap-3 shadow-lg">
        <i class="fa-solid fa-circle-check text-base animate-pulse"></i>
        <span>Data Knowledge Base AI Berhasil Diperbarui di Supabase! Mesin sinkronisasi OpenClaw otomatis ter-refresh.</span>
      </div>
    <% } %>

    <% if (typeof req !== 'undefined' && req.query.user_added) { %>
      <div class="mb-6 rounded-2xl border border-blue-500/20 bg-blue-500/10 p-4 text-xs font-semibold text-blue-400 flex items-center gap-3 shadow-lg">
        <i class="fa-solid fa-user-check text-base animate-pulse"></i>
        <span>Akun administrator baru berhasil didaftarkan ke database Supabase dan bisa langsung digunakan untuk login!</span>
      </div>
    <% } %>

    <div class="rounded-[2rem] bg-slate-900/40 border border-slate-800 p-6 md:p-8 glow-effect mb-8">
      <form action="/admin/ai-config/save" method="POST" class="space-y-6">
        
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
            <i class="fa-solid fa-brain text-indigo-400"></i> Robot System Instruction (Kepribadian AI)
          </label>
          <p class="text-[11px] text-slate-500 mb-3 leading-relaxed">
            Aturan limitasi perilaku mutlak robot. Perintah di sini memaksa Gemini untuk menolak pertanyaan di luar ruang lingkup (contoh: coding, memasak) menggunakan format tag khusus.
          </p>
          <textarea name="system_instruction" rows="5" required placeholder="Tulis instruksi sistem untuk membatasi ruang lingkup chat AI di sini..." class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3.5 text-xs text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-sans leading-relaxed"><%= config?.system_instruction || '' %></textarea>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
            <i class="fa-solid fa-book-bookmark text-cyan-400"></i> Knowledge Base (Basis Pengetahuan Beasiswa)
          </label>
          <p class="text-[11px] text-slate-500 mb-3 leading-relaxed">
            Suapi data sedetail mungkin (Persyaratan administrasi, nominal pencairan dana, jadwal seleksi, alamat helpdesk) agar AI mampu melakukan pencocokan jawaban secara valid.
          </p>
          <textarea name="knowledge_base" rows="12" required placeholder="Tulis semua dokumen atau informasi penting seputar beasiswa di sini..." class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3.5 text-xs text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-mono leading-relaxed"><%= config?.knowledge_base || '' %></textarea>
        </div>

        <div class="border-t border-slate-800/80 pt-6 flex flex-col sm:flex-row gap-3">
          <button type="submit" class="w-full sm:flex-grow rounded-xl bg-gradient-to-r from-cyan-500 to-indigo-600 px-6 py-4 text-xs font-bold text-white transition hover:from-cyan-400 hover:to-indigo-500 shadow-xl shadow-indigo-600/5 hover:scale-[1.01]">
            <i class="fa-solid fa-floppy-disk mr-1.5"></i> Simpan & Perbarui Memori Engine AI
          </button>
          <a href="/admin" class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-slate-950 border border-slate-800 px-6 py-4 text-xs font-bold text-slate-400 transition hover:bg-slate-800 hover:text-slate-200">
            Batal
          </a>
        </div>

      </form>
    </div>

    <div class="rounded-[2rem] bg-slate-900/40 border border-slate-800 p-6 md:p-8">
      <div class="mb-6 flex items-center gap-3 border-b border-slate-800/80 pb-4">
        <span class="text-2xl">👥</span>
        <div>
          <h2 class="text-xl font-bold text-white">Manajemen Otoritas Tim</h2>
          <p class="text-xs text-slate-500 mt-0.5">Daftarkan akun administrator pendukung dengan pembagian hak akses (*multi-role system*).</p>
        </div>
      </div>

      <form action="/admin/ai-config/add-admin" method="POST" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-3">
          
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Username Staff</label>
            <div class="relative flex items-center">
              <span class="absolute left-4 text-slate-600 text-xs"><i class="fa-solid fa-user"></i></span>
              <input 
                type="text" 
                name="new_username" 
                placeholder="Contoh: staff_admin_kel7" 
                required 
                class="w-full bg-slate-950 border border-slate-800 rounded-xl pl-11 pr-4 py-3.5 text-xs text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-sans"
              />
            </div>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Password Akun</label>
            <div class="relative flex items-center">
              <span class="absolute left-4 text-slate-600 text-xs"><i class="fa-solid fa-lock"></i></span>
              <input 
                type="password" 
                name="new_password" 
                placeholder="Masukkan pass-key..." 
                required 
                class="w-full bg-slate-950 border border-slate-800 rounded-xl pl-11 pr-4 py-3.5 text-xs text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-sans"
              />
            </div>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Tingkat Otoritas (Role)</label>
            <div class="relative flex items-center">
              <span class="absolute left-4 text-slate-600 text-xs"><i class="fa-solid fa-ranking-star"></i></span>
              <select name="new_role" required class="w-full bg-slate-950 border border-slate-800 rounded-xl pl-11 pr-4 py-3.5 text-xs font-semibold text-slate-400 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 appearance-none cursor-pointer">
                <option value="admin">admin (Hanya Kirim Broadcast)</option>
                <option value="kepala admin">kepala admin (Akses Otoritas Penuh)</option>
              </select>
            </div>
          </div>

        </div>

        <button type="submit" class="w-full rounded-xl bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-4 text-xs font-bold text-white transition hover:from-emerald-500 hover:to-teal-500 shadow-xl shadow-emerald-600/5 hover:scale-[1.01] mt-2">
          <i class="fa-solid fa-user-plus mr-1 text-[10px]"></i> Daftarkan Hak Akses Operator Baru
        </button>
      </form>
    </div>

  </div>

  <script>
    if (window.location.search.includes('success=1')) {
      const msg = document.createElement('div');
      msg.className = "fixed bottom-5 right-5 rounded-xl bg-slate-900 border border-emerald-500/30 text-emerald-400 font-bold text-xs py-3.5 px-5 shadow-2xl transition duration-500 z-50 flex items-center gap-2";
      msg.innerHTML = "<i class='fa-solid fa-circle-check animate-bounce'></i> 🎉 Sukses sinkronisasi memori basis data AI!";
      document.body.appendChild(msg);
      setTimeout(() => msg.remove(), 4000);
    }

    if (window.location.search.includes('user_added=1')) {
      const msg = document.createElement('div');
      msg.className = "fixed bottom-5 right-5 rounded-xl bg-slate-900 border border-blue-500/30 text-blue-400 font-bold text-xs py-3.5 px-5 shadow-2xl transition duration-500 z-50 flex items-center gap-2";
      msg.innerHTML = "<i class='fa-solid fa-user-shield animate-bounce'></i> 👤 Akun administrator baru berhasil terdaftar!";
      document.body.appendChild(msg);
      setTimeout(() => msg.remove(), 4000);
    }
  </script>
</body>
</html>