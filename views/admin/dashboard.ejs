<%- include('partials/header') %>

<div class="mx-auto max-w-6xl z-10 relative theme-transition">

  <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-4 mb-8">
    
    <div class="rounded-3xl bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 p-6 flex flex-col justify-between hover:border-slate-300 dark:hover:border-slate-700/50 transition shadow-sm">
      <div class="flex justify-between items-start">
        <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Total Subscribers</p>
        <span class="text-blue-600 dark:text-blue-400 bg-blue-500/10 w-7 h-7 rounded-lg flex items-center justify-center text-xs"><i class="fa-solid fa-users"></i></span>
      </div>
      <h2 class="mt-4 text-4xl font-black text-slate-900 dark:text-white tracking-tight font-mono"><%= users.length %></h2>
    </div>

    <div class="rounded-3xl bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 p-6 flex flex-col justify-between hover:border-slate-300 dark:hover:border-slate-700/50 transition shadow-sm">
      <div class="flex justify-between items-start">
        <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Tiket Luar Konteks</p>
        <span class="text-amber-600 dark:text-amber-400 bg-amber-500/10 w-7 h-7 rounded-lg flex items-center justify-center text-xs"><i class="fa-solid fa-triangle-exclamation"></i></span>
      </div>
      <h2 class="mt-4 text-4xl font-black text-amber-600 dark:text-amber-400 tracking-tight font-mono"><%= typeof pendingTicketsCount !== 'undefined' ? pendingTicketsCount : 0 %></h2>
    </div>

    <div class="rounded-3xl bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800/60 p-6 shadow-sm theme-transition relative overflow-hidden flex flex-col justify-between">
          <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-500/5 rounded-bl-full pointer-events-none"></div>
          <div>
            <div class="flex items-center justify-between">
              <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">API Router Monitor</span>
              <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
              </span>
            </div>
            <div class="mt-4 flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-xl shadow-inner">
                <i class="fa-solid fa-circle-nodes"></i>
              </div>
              <div>
                <p class="text-lg font-black text-slate-900 dark:text-white tracking-tight">Gateway Active</p>
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400">Engine Ready</p>
              </div>
            </div>
          </div>
          <p class="mt-4 text-[10px] font-bold text-slate-600 dark:text-slate-400 bg-slate-50 dark:bg-slate-950/60 rounded-xl p-2.5 border border-slate-200 dark:border-slate-800/80 font-mono">
            🔑 Key Aktif: <span class="text-indigo-600 dark:text-indigo-400 font-extrabold"><%= typeof totalApiKeys !== 'undefined' ? totalApiKeys : (global.totalApiKeysCount || 1) %> Pool</span>
          </p>
      </div>
    <div class="rounded-3xl bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 p-6 flex flex-col justify-between hover:border-slate-300 dark:hover:border-slate-700/50 transition shadow-sm">
      <div class="flex justify-between items-start">
        <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Broadcast Engine</p>
        <span class="text-purple-600 dark:text-purple-400 bg-purple-500/10 w-7 h-7 rounded-lg flex items-center justify-center text-xs"><i class="fa-solid fa-bullhorn"></i></span>
      </div>
      <h2 class="mt-4 text-base font-bold text-purple-600 dark:text-purple-400 flex items-center gap-1.5">
        <i class="fa-solid fa-circle-check text-xs"></i> Ready to Dispatch
      </h2>
    </div>
  </div>

  <div class="mb-8 rounded-[2rem] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 p-6 md:p-8 shadow-sm theme-transition">
    <div class="mb-6 flex items-center gap-3 border-b border-slate-100 dark:border-slate-800/80 pb-4">
      <span class="text-2xl">📢</span>
      <div>
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Transmisi Pesan Massal</h2>
        <p class="text-xs text-slate-500 mt-0.5">Kirim pengumuman resmi berkas lampiran ke seluruh atau individu pendaftar Telegram.</p>
      </div>
    </div>

    <form action="/admin/broadcast" method="POST" enctype="multipart/form-data" class="space-y-5">
      <div>
        <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Target Penerima Dokumen</label>
        <select name="target_chat_id" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3.5 text-xs font-semibold text-slate-800 dark:text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
          <option value="">📣 Penyiaran Massal: Kirim ke SEMUA Pendaftar Terdata (<%= users.length %> User)</option>
          <% users.forEach(function(u) { %>
            <option value="<%= u.chat_id %>">👤 <%= u.full_name || 'Tanpa Nama' %> (@<%= u.username || '-' %>) — [ID: <%= u.chat_id %>]</option>
          <% }); %>
        </select>
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Konten Narasi Penyiaran</label>
        <textarea name="pesan" rows="5" placeholder="Tulis instruksi atau info beasiswa di sini..." required class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3.5 text-xs text-slate-800 dark:text-slate-300 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 resize-none font-sans leading-relaxed"></textarea>
        <p class="mt-2 text-[10px] text-slate-500 flex items-center gap-1"><i class="fa-solid fa-lightbulb"></i> Tips format markdown didukung: Gunakan rumus *teks tebal* untuk memberikan penekanan.</p>
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Dokumen Lampiran Tambahan (Opsional)</label>
        <input type="file" name="file" class="w-full bg-slate-50 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800 border-dashed rounded-xl p-3 text-xs text-slate-600 dark:text-slate-400 outline-none transition focus:border-indigo-500 cursor-pointer file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-[10px] file:font-bold file:bg-indigo-500/10 file:text-indigo-600 dark:file:text-indigo-400 file:hover:bg-indigo-500/20" />
      </div>

      <button type="submit" class="w-full rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4 text-xs font-bold text-white transition hover:from-blue-500 hover:to-indigo-500 shadow-xl shadow-indigo-600/5 hover:scale-[1.01] cursor-pointer">
        <i class="fa-solid fa-paper-plane mr-1 text-[10px]"></i> Eksekusi dan Kirim Broadcast Sekarang
      </button>
    </form>
  </div>

  <div class="rounded-[2rem] bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 p-6 md:p-8 shadow-sm theme-transition">
    <div class="mb-6 flex items-center gap-3">
      <span class="text-2xl">👥</span>
      <div>
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Database Akun Pendaftar</h2>
        <p class="text-xs text-slate-500 mt-0.5">Daftar pengguna Telegram yang telah menekan fungsi start dan terdaftar di basis data.</p>
      </div>
    </div>

    <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-800/80 shadow-sm">
      <table class="w-full border-collapse text-left text-xs">
        <thead>
          <tr class="bg-slate-100 dark:bg-slate-950 text-slate-600 dark:text-slate-400 border-b border-slate-200 dark:border-slate-800 font-mono uppercase tracking-wider text-[10px]">
            <th class="px-6 py-4 font-bold">No</th>
            <th class="px-6 py-4 font-bold">Nama Lengkap</th>
            <th class="px-6 py-4 font-bold">Username Telegram</th>
            <th class="px-6 py-4 font-bold text-right">Unique Chat ID</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 dark:divide-slate-800/60 bg-white dark:bg-slate-900/20">
          <% if (users.length === 0) { %>
            <tr>
              <td colspan="4" class="px-6 py-8 text-center text-slate-400 dark:text-slate-500 font-medium italic">Belum ada akun pengguna pendaftar yang terdeteksi di database Supabase.</td>
            </tr>
          <% } else { %>
            <% users.forEach(function(u, i) { %>
              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition duration-150">
                <td class="px-6 py-4 font-mono text-slate-400 dark:text-slate-500"><%= i + 1 %></td>
                <td class="px-6 py-4 font-bold text-slate-900 dark:text-white"><%= u.full_name || '❓ Belum mengisi nama' %></td>
                <td class="px-6 py-4 text-slate-600 dark:text-slate-400">
                  <% if (u.username) { %>
                    <span class="text-indigo-600 dark:text-indigo-400 font-semibold">@<%= u.username %></span>
                  <% } else { %>
                    <span class="text-slate-400 dark:text-slate-600 font-normal italic">tidak ada</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 font-mono text-right text-cyan-600 dark:text-cyan-400 font-semibold tracking-wide"><%= u.chat_id %></td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  
</div>

<%- include('partials/footer') %>