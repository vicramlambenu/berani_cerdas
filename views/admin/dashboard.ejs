<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - Berani Cerdas</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <style>
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .card-shadow { box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2); }
  </style>
</head>
<body class="min-h-screen p-4 md:p-8 text-slate-900">
  <div class="mx-auto max-w-6xl">
    
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-4xl font-extrabold text-white drop-shadow-lg">🎓 Berani Cerdas Admin</h1>
        <p class="mt-2 text-blue-100">Dashboard Administrator (<%= adminUser %> - <span class="capitalize"><%= adminRole %></span>)</p>
      </div>
      <a href="/admin/logout" class="inline-flex items-center justify-center rounded-2xl bg-red-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-red-600 shadow-lg">
        🚪 Logout
      </a>
    </div>

    <div class="mb-8 flex flex-wrap gap-4">
      <a href="/admin/ai-config" class="inline-flex items-center gap-2 rounded-2xl bg-gradient-to-r from-cyan-500 to-blue-600 px-6 py-3.5 text-sm font-bold text-white transition hover:from-cyan-600 hover:to-blue-700 shadow-lg hover:scale-[1.02] active:scale-[0.98]">
        ⚙️ Pengaturan AI & Knowledge Base
      </a>

      <% if (adminRole === 'kepala admin') { %>
        <a href="/admin/logs" class="inline-flex items-center gap-2 rounded-2xl bg-slate-800 px-6 py-3.5 text-sm font-bold text-white transition hover:bg-slate-900 shadow-lg hover:scale-[1.02] active:scale-[0.98]">
          📋 Lihat Log Audit Sistem
        </a>
      <% } %>
    </div>
    <div class="grid gap-6 md:grid-cols-3 mb-8">
      <div class="rounded-3xl bg-white p-6 card-shadow">
        <p class="text-sm font-semibold text-slate-500">Total Users</p>
        <h2 class="mt-4 text-4xl font-black text-blue-600"><%= users.length %></h2>
      </div>
      <div class="rounded-3xl bg-white p-6 card-shadow">
        <p class="text-sm font-semibold text-slate-500">Status</p>
        <h2 class="mt-4 text-2xl font-bold text-emerald-600">🟢 Online</h2>
      </div>
      <div class="rounded-3xl bg-white p-6 card-shadow">
        <p class="text-sm font-semibold text-slate-500">Broadcast</p>
        <h2 class="mt-4 text-2xl font-bold text-purple-600">Ready</h2>
      </div>
    </div>

    <div class="mb-8 rounded-3xl bg-white p-8 card-shadow">
      <div class="mb-8 flex items-center gap-3 text-gray-800">
        <span class="text-4xl">📢</span>
        <h2 class="text-2xl font-bold">Kirim Broadcast</h2>
      </div>

      <form action="/admin/broadcast" method="POST" enctype="multipart/form-data" class="space-y-6">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Target Penerima</label>
          <select name="target_chat_id" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200">
            <option value="">📣 Kirim ke SEMUA User (<%= users.length %> user)</option>
            <% users.forEach(function(u) { %>
              <option value="<%= u.chat_id %>">👤 <%= u.full_name || '-' %> (@<%= u.username || '-' %>)</option>
            <% }); %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Pesan</label>
          <textarea name="pesan" rows="6" placeholder="Tulis pesan broadcast Anda di sini..." required class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200 resize-none"></textarea>
          <p class="mt-2 text-xs text-slate-500">💡 Tips: Gunakan *bold* untuk teks tebal</p>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Lampirkan File (Opsional)</label>
          <input type="file" name="file" class="w-full rounded-2xl border border-slate-300 p-3 text-slate-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200 cursor-pointer" />
          <p class="mt-2 text-xs text-slate-500">📎 PDF, Word, atau file lainnya</p>
        </div>

        <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-4 text-sm font-semibold text-white transition hover:from-blue-700 hover:to-purple-700">
          🚀 Kirim Broadcast Sekarang
        </button>
      </form>
    </div>

    <div class="rounded-3xl bg-white p-8 card-shadow">
      <div class="mb-6 flex items-center gap-3 text-gray-800">
        <span class="text-3xl">👥</span>
        <h2 class="text-2xl font-bold">Daftar User (<%= users.length %>)</h2>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-left text-sm">
          <thead>
            <tr class="bg-gradient-to-r from-blue-100 to-purple-100 text-slate-700">
              <th class="px-6 py-3 font-semibold">No</th>
              <th class="px-6 py-3 font-semibold">Nama</th>
              <th class="px-6 py-3 font-semibold">Username</th>
              <th class="px-6 py-3 font-semibold">Chat ID</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u, i) { %>
              <tr class="border-b bg-slate-50 hover:bg-blue-50 transition">
                <td class="px-6 py-4"><%= i + 1 %></td>
                <td class="px-6 py-4 font-semibold text-slate-800"><%= u.full_name || '❓ Belum diisi' %></td>
                <td class="px-6 py-4 text-slate-600">@<%= u.username || '-' %></td>
                <td class="px-6 py-4 font-mono text-blue-600"><%= u.chat_id %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>